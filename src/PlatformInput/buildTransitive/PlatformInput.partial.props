<Project>
    <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
        <Using Alias="PlatformDefaultInputDevice" Include="SharpSticks.DirectInput.DirectInputJoystickDevice"/>
        <Using Alias="PlatformDefaultInputDeviceFactory" Include="SharpSticks.DirectInput.DirectInputJoystickDeviceFactory"/>
    </ItemGroup>
    <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
        <Using Alias="PlatformDefaultInputDevice" Include="SharpSticks.LinuxInput.LinuxInputJoystickDevice"/>
        <Using Alias="PlatformDefaultInputDeviceFactory" Include="SharpSticks.LinuxInput.LinuxInputJoystickDeviceFactory"/>
    </ItemGroup>
</Project>
