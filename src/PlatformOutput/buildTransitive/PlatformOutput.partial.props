<Project>
    <Choose>
        <When Condition="$([MSBuild]::IsOSPlatform('Windows'))">
            <PropertyGroup>
                <PlatformDefaultOutputDeviceTypeName>VJoyDevice</PlatformDefaultOutputDeviceTypeName>
                <PlatformDefaultOutputDeviceFullTypeName>SharpSticks.VJoy.$(PlatformDefaultOutputDeviceTypeName)</PlatformDefaultOutputDeviceFullTypeName>
                <PlatformDefaultOutputDeviceFactoryTypeName>VJoyDeviceFactory</PlatformDefaultOutputDeviceFactoryTypeName>
                <PlatformDefaultOutputDeviceFactoryFullTypeName>SharpSticks.VJoy.$(PlatformDefaultOutputDeviceFactoryTypeName)</PlatformDefaultOutputDeviceFactoryFullTypeName>
            </PropertyGroup>
        </When>
        <When Condition="$([MSBuild]::IsOSPlatform('Linux'))">
            <PropertyGroup>
                <PlatformDefaultOutputDeviceTypeName>LinuxOutputDevice</PlatformDefaultOutputDeviceTypeName>
                <PlatformDefaultOutputDeviceFullTypeName>SharpSticks.LinuxOutput.$(PlatformDefaultOutputDeviceTypeName)</PlatformDefaultOutputDeviceFullTypeName>
                <PlatformDefaultOutputDeviceFactoryTypeName>LinuxOutputDeviceFactory</PlatformDefaultOutputDeviceFactoryTypeName>
                <PlatformDefaultOutputDeviceFactoryFullTypeName>SharpSticks.LinuxOutput.$(PlatformDefaultOutputDeviceFactoryTypeName)</PlatformDefaultOutputDeviceFactoryFullTypeName>
            </PropertyGroup>
        </When>
    </Choose>

    <Choose>
        <When Condition="'$(PlatformDefaultOutputDeviceFullTypeName)' != ''">
            <ItemGroup>
                <Using Alias="PlatformDefaultOutputDevice" Include="$(PlatformDefaultOutputDeviceFullTypeName)"/>
            </ItemGroup>
        </When>
    </Choose>
    <Choose>
        <When Condition="'$(PlatformDefaultOutputDeviceFactoryFullTypeName)' != ''">
            <ItemGroup>
                <Using Alias="PlatformDefaultOutputDeviceFactory" Include="$(PlatformDefaultOutputDeviceFactoryFullTypeName)"/>
            </ItemGroup>
        </When>
    </Choose>
</Project>
