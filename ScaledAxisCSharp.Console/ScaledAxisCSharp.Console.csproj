<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <UseGeneratorPackageReference Condition="'$(UseGeneratorPackageReference)' == ''">true</UseGeneratorPackageReference>
    </PropertyGroup>

    <ItemGroup>
        <ScaledAxisCSharpExportAnalyzerProject Include="ScaledAxisCSharp.Generators\ScaledAxisCSharp.Generators.csproj"/>
    </ItemGroup>

    <Choose>
        <When Condition="'$(UseGeneratorPackageReference)' == 'true'">
            <ItemGroup>
                <ProjectReference Include="..\ScaledAxisCSharp.Generators\ScaledAxisCSharp.Generators.csproj"
                                  IncludeAssets="analyzers;buildtransitive"
                                  PrivateAssets="contentfiles;build"/>
            </ItemGroup>
        </When>
        <Otherwise>
            <ItemGroup>
                <ProjectReference Include="..\ScaledAxisCSharp.Generators\ScaledAxisCSharp.Generators.csproj"
                                  OutputItemType="Analyzer"
                                  ReferenceOutputAssembly="false"
                                  PrivateAssets="all"/>
            </ItemGroup>
        </Otherwise>
    </Choose>

    <ItemGroup>
        <ProjectReference Include="..\ScaledAxisCSharp.Config\ScaledAxisCSharp.Config.csproj"/>
    </ItemGroup>

</Project>
