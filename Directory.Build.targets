<Project>
    <Import Condition="'$(SharedPropsLoaded)' != 'true' and exists('$(MSBuildThisFileDirectory)Shared.props')" Project="$(MSBuildThisFileDirectory)Shared.props"/>
    <ItemGroup>
        <PackageReference Include="MinVer" Version="7.0.0" PrivateAssets="all"
                          IncludeAssets="runtime; build; native; contentfiles; analyzers; buildtransitive"/>
    </ItemGroup>

    <Target Name="GenerateBuildTransitiveProps"
            BeforeTargets="Build;Pack"
            Condition="'$(OutputType)' != 'Exe' and '$(NoAutoProps)' != 'true'">
        <PropertyGroup>
            <_BuildTransitiveDir>$(MSBuildProjectDirectory)\buildTransitive\</_BuildTransitiveDir>
            <_BuildTransitiveFile>$(_BuildTransitiveDir)$(MSBuildProjectName).props</_BuildTransitiveFile>
            <_BuildTransitivePartialFile>$(_BuildTransitiveDir)$(MSBuildProjectName).partial.props</_BuildTransitivePartialFile>
            <_BuildTransitivePackFile>$(MSBuildProjectDirectory)\$(BaseIntermediateOutputPath)pack-buildTransitive\$(MSBuildProjectName).props</_BuildTransitivePackFile>
        </PropertyGroup>
        <ItemGroup>
            <_ProjRefProps Include="%(ProjectReference.RootDir)%(ProjectReference.Directory)buildTransitive\%(ProjectReference.Filename).props"
                           Condition="Exists('%(ProjectReference.RootDir)%(ProjectReference.Directory)buildTransitive\%(ProjectReference.Filename).props')"/>
            <_PartialProps Include="$(_BuildTransitivePartialFile)"
                           Condition="Exists('$(_BuildTransitivePartialFile)')"/>
            <_ExportedUsings Include="$(RootNamespace)|"
                             Condition="'$(RootNamespace)' != ''">
                <UsingInclude>$(RootNamespace)</UsingInclude>
                <Alias></Alias>
                <HasAliasAttribute>false</HasAliasAttribute>
            </_ExportedUsings>
            <_ExportedAnalyzerProjects Include="@(ScaledAxisCSharpExportAnalyzerProject)"/>
        </ItemGroup>
        <ReadLinesFromFile File="%(_ProjRefProps.Identity)"
                           Condition="'@(_ProjRefProps)' != ''">
            <Output TaskParameter="Lines" ItemName="_ExportedUsingLines"/>
        </ReadLinesFromFile>
        <ReadLinesFromFile File="%(_PartialProps.Identity)"
                           Condition="'@(_PartialProps)' != ''">
            <Output TaskParameter="Lines" ItemName="_ExportedUsingLines"/>
        </ReadLinesFromFile>
        <ItemGroup>
            <_ParsedExportedUsingLines Include="@(_ExportedUsingLines)">
                <UsingInclude>$([System.Text.RegularExpressions.Regex]::Match('%(_ExportedUsingLines.Identity)', 'Include=&quot;([^&quot;]+)&quot;').Groups[1].Value)</UsingInclude>
                <Alias>$([System.Text.RegularExpressions.Regex]::Match('%(_ExportedUsingLines.Identity)', 'Alias=&quot;([^&quot;]*)&quot;').Groups[1].Value)</Alias>
                <HasAliasAttribute>$([System.Text.RegularExpressions.Regex]::IsMatch('%(_ExportedUsingLines.Identity)', 'Alias=&quot;[^&quot;]*&quot;').ToString().ToLowerInvariant())</HasAliasAttribute>
                <IsUsingLine>$([System.Text.RegularExpressions.Regex]::IsMatch('%(_ExportedUsingLines.Identity)', '^\s*&lt;Using\b').ToString().ToLowerInvariant())</IsUsingLine>
            </_ParsedExportedUsingLines>
            <_ExportedUsings Include="%(_ParsedExportedUsingLines.UsingInclude)|%(_ParsedExportedUsingLines.Alias)"
                             Condition="'%(_ParsedExportedUsingLines.IsUsingLine)' == 'true' and '%(_ParsedExportedUsingLines.UsingInclude)' != ''">
                <UsingInclude>%(_ParsedExportedUsingLines.UsingInclude)</UsingInclude>
                <Alias>%(_ParsedExportedUsingLines.Alias)</Alias>
                <HasAliasAttribute>%(_ParsedExportedUsingLines.HasAliasAttribute)</HasAliasAttribute>
            </_ExportedUsings>
        </ItemGroup>
        <XmlPeek XmlInputPath="%(_ProjRefProps.Identity)"
                 Query="/Project/ItemGroup/ScaledAxisCSharpTransitiveAnalyzerProject[string-length(@Include) &gt; 0]/@Include"
                 Condition="'@(_ProjRefProps)' != ''">
            <Output TaskParameter="Result" ItemName="_ExportedAnalyzerProjects"/>
        </XmlPeek>
        <RemoveDuplicates Inputs="@(_ExportedUsings)">
            <Output TaskParameter="Filtered" ItemName="_DistinctExportedUsings"/>
        </RemoveDuplicates>
        <RemoveDuplicates Inputs="@(_ExportedAnalyzerProjects)">
            <Output TaskParameter="Filtered" ItemName="_DistinctExportedAnalyzerProjects"/>
        </RemoveDuplicates>
        <ItemGroup>
            <_PropsFileLines Include="&lt;Project&gt;"/>
            <_PropsFileLines Include="  &lt;ItemGroup&gt;"/>
            <_PropsFileLines Include="    &lt;Using Include=&quot;%(_DistinctExportedUsings.UsingInclude)&quot; Alias=&quot;%(_DistinctExportedUsings.Alias)&quot; /&gt;"
                             Condition="'%(_DistinctExportedUsings.HasAliasAttribute)' == 'true' or '%(_DistinctExportedUsings.Alias)' != ''"/>
            <_PropsFileLines Include="    &lt;Using Include=&quot;%(_DistinctExportedUsings.UsingInclude)&quot; /&gt;"
                             Condition="'%(_DistinctExportedUsings.HasAliasAttribute)' != 'true' and '%(_DistinctExportedUsings.Alias)' == ''"/>
            <_PropsFileLines Include="    &lt;ScaledAxisCSharpTransitiveAnalyzerProject Include=&quot;%(_DistinctExportedAnalyzerProjects.Identity)&quot; /&gt;"
                             Condition="'%(_DistinctExportedAnalyzerProjects.Identity)' != ''"/>
            <_PropsFileLines Include="  &lt;/ItemGroup&gt;"/>
            <_PropsFileLines Include="&lt;/Project&gt;"/>
        </ItemGroup>
        <ItemGroup>
            <_PackPropsFileLines Include="&lt;Project&gt;"/>
            <_PackPropsFileLines Include="  &lt;ItemGroup&gt;"/>
            <_PackPropsFileLines Include="    &lt;Using Include=&quot;%(_DistinctExportedUsings.UsingInclude)&quot; Alias=&quot;%(_DistinctExportedUsings.Alias)&quot; /&gt;"
                                 Condition="'%(_DistinctExportedUsings.HasAliasAttribute)' == 'true' or '%(_DistinctExportedUsings.Alias)' != ''"/>
            <_PackPropsFileLines Include="    &lt;Using Include=&quot;%(_DistinctExportedUsings.UsingInclude)&quot; /&gt;"
                                 Condition="'%(_DistinctExportedUsings.HasAliasAttribute)' != 'true' and '%(_DistinctExportedUsings.Alias)' == ''"/>
            <_PackPropsFileLines Include="  &lt;/ItemGroup&gt;"/>
            <_PackPropsFileLines Include="&lt;/Project&gt;"/>
        </ItemGroup>
        <MakeDir Directories="$(_BuildTransitiveDir);$([System.IO.Path]::GetDirectoryName($(_BuildTransitivePackFile)))"/>
        <WriteLinesToFile File="$(_BuildTransitiveFile)" Lines="@(_PropsFileLines)" Overwrite="true" WriteOnlyWhenDifferent="true"/>
        <WriteLinesToFile File="$(_BuildTransitivePackFile)" Lines="@(_PackPropsFileLines)" Overwrite="true" WriteOnlyWhenDifferent="true"/>
        <ItemGroup>
            <None Include="$(_BuildTransitivePackFile)" Pack="true" PackagePath="buildTransitive\$(MSBuildProjectName).props"/>
        </ItemGroup>
    </Target>


    <Target Name="ImportProjectRefBuildTransitiveUsings"
            BeforeTargets="GenerateGlobalUsings">
        <MSBuild Projects="@(ProjectReference)"
                 Targets="GenerateBuildTransitiveProps"
                 Properties="Configuration=$(Configuration)"
                 BuildInParallel="$(BuildInParallel)"
                 ContinueOnError="WarnAndContinue"
                 Condition="'@(ProjectReference)' != ''"/>
        <ItemGroup>
            <_ProjRefProps Include="%(ProjectReference.RootDir)%(ProjectReference.Directory)buildTransitive\%(ProjectReference.Filename).props"
                           Condition="Exists('%(ProjectReference.RootDir)%(ProjectReference.Directory)buildTransitive\%(ProjectReference.Filename).props')"/>
        </ItemGroup>
        <ReadLinesFromFile File="%(_ProjRefProps.Identity)"
                           Condition="'@(_ProjRefProps)' != ''">
            <Output TaskParameter="Lines" ItemName="_ImportedProjectRefUsingLines"/>
        </ReadLinesFromFile>
        <ItemGroup>
            <_ParsedImportedProjectRefUsingLines Include="@(_ImportedProjectRefUsingLines)">
                <UsingInclude>$([System.Text.RegularExpressions.Regex]::Match('%(_ImportedProjectRefUsingLines.Identity)', 'Include=&quot;([^&quot;]+)&quot;').Groups[1].Value)</UsingInclude>
                <Alias>$([System.Text.RegularExpressions.Regex]::Match('%(_ImportedProjectRefUsingLines.Identity)', 'Alias=&quot;([^&quot;]*)&quot;').Groups[1].Value)</Alias>
                <IsUsingLine>$([System.Text.RegularExpressions.Regex]::IsMatch('%(_ImportedProjectRefUsingLines.Identity)', '^\s*&lt;Using\b').ToString().ToLowerInvariant())</IsUsingLine>
            </_ParsedImportedProjectRefUsingLines>
            <_ImportedProjectRefUsings Include="%(_ParsedImportedProjectRefUsingLines.UsingInclude)|%(_ParsedImportedProjectRefUsingLines.Alias)"
                                      Condition="'%(_ParsedImportedProjectRefUsingLines.IsUsingLine)' == 'true' and '%(_ParsedImportedProjectRefUsingLines.UsingInclude)' != ''">
                <UsingInclude>%(_ParsedImportedProjectRefUsingLines.UsingInclude)</UsingInclude>
                <Alias>%(_ParsedImportedProjectRefUsingLines.Alias)</Alias>
            </_ImportedProjectRefUsings>
        </ItemGroup>
        <RemoveDuplicates Inputs="@(_ImportedProjectRefUsings)">
            <Output TaskParameter="Filtered" ItemName="_DistinctImportedProjectRefUsings"/>
        </RemoveDuplicates>
        <ItemGroup>
            <Using Include="%(_DistinctImportedProjectRefUsings.UsingInclude)"
                   Condition="'@(_DistinctImportedProjectRefUsings)' != ''">
                <Alias>%(_DistinctImportedProjectRefUsings.Alias)</Alias>
            </Using>
        </ItemGroup>
    </Target>

    <Target Name="ImportProjectRefBuildTransitiveAnalyzers"
            BeforeTargets="CoreCompile"
            DependsOnTargets="ImportProjectRefBuildTransitiveUsings">
        <XmlPeek XmlInputPath="%(_ProjRefProps.Identity)"
                 Query="/Project/ItemGroup/ScaledAxisCSharpTransitiveAnalyzerProject[string-length(@Include) &gt; 0]/@Include"
                 Condition="'@(_ProjRefProps)' != ''">
            <Output TaskParameter="Result" ItemName="_ImportedTransitiveAnalyzerProjects"/>
        </XmlPeek>
        <ItemGroup>
            <_TransitiveAnalyzerProject Include="$(MSBuildThisFileDirectory)%(_ImportedTransitiveAnalyzerProjects.Identity)"
                                        Condition="'@(_ImportedTransitiveAnalyzerProjects)' != '' and Exists('$(MSBuildThisFileDirectory)%(_ImportedTransitiveAnalyzerProjects.Identity)')"/>
        </ItemGroup>
        <MSBuild Projects="@(_TransitiveAnalyzerProject)"
                 Targets="GetTargetPath"
                 Properties="Configuration=$(Configuration)"
                 BuildInParallel="$(BuildInParallel)"
                 Condition="'@(_TransitiveAnalyzerProject)' != ''">
            <Output TaskParameter="TargetOutputs" ItemName="_TransitiveAnalyzerOutput"/>
        </MSBuild>
        <ItemGroup>
            <Analyzer Include="@(_TransitiveAnalyzerOutput)"/>
        </ItemGroup>
    </Target>

</Project>
